local function main()
    startSpinner()
    local success = sendJobId()
    if success then
        wait(1)
        updateDisplay()
        
        while true do
            task.wait(3)
            updateDisplay()
        end
    else
        StatusText.Text = "Bağlantı hatası!"
        StatusText.TextColor3 = Color3.fromRGB(255, 80, 80)
        LoadingSpinner.BackgroundTransparency = 1
        SpinnerCircle.BackgroundTransparency = 1
        stopSpinner()
        
        EmptyCard.Visible = true
        EmptyText.Text = "Veritabanına bağlanılamadı"
    end
end

task.spawn(main)
