	end

	local function komutIsle(text)
		if not text or text == "" then return end

		if sts_simdiMi(text) then
			sts_bakKapatVeYerlestir()
			return
		end

		if ileriMi(text) then
			sflKapat()
			aciKorumayiDurdur()
			sabitAciBelirlendi = false
			if humanoid then
				humanoid.AutoRotate = true
				humanoid.WalkSpeed = 16
			end
			local h = tak_komBul()
			if h then tak_basla(h) end
			return
		end

		if parkurMu(text) then
			fr_parkurTextAlgilandi()
			return
		end

		local kk = text:lower():gsub("%s+", "")

		if kk == "sag" or kk == "sağ" or kk == "right" then
			don_don("sag")
			return
		end
		if kk == "sol" or kk == "left" then
			don_don("sol")
			return
		end
		if kk == "geri" or kk == "back" or kk == "arka" then
			don_don("geri")
			return
		end
		if kk == "merkez" or kk == "center" or kk == "on" then
			don_don("merkez")
			return
		end

		if kk == "sfl" or kk == "tsk" then
			tak_durdur()
			sflAc()
			return
		end

		if kk == "sflkapat" or kk == "tskkapat" then
			sflKapat()
			return
		end

		local idx = text:lower():match("sfl git (%d+)") or text:lower():match("tsk git (%d+)")
		if idx then
			idx = tonumber(idx)
			if idx and idx >= 1 and idx <= TOPLAM_POZISYON then
				if takipAktif then tak_durdur() end
				pozisyonDegistir(idx, false)
			end
			return
		end

		if kk == "sts" then
			sflKapat()
			tak_durdur()
			task.wait(0.05)
			if not sts_aktif then
				sts_toggle()
			end
			return
		end
	end

