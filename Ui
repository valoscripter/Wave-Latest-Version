local function notify(content, isError)
    local msg = Instance.new("TextLabel")
    msg.Size = UDim2.new(0, 300, 0, 40)
    msg.Position = UDim2.new(0.5, -150, 0, -50)
    msg.AnchorPoint = Vector2.new(0.5, 0)
