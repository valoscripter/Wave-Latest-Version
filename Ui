		if not t then return false end
		local k = t:lower():gsub("%s+", "")
		for _, v in ipairs({"ileri", "mars", "marş", "ilerimars", "ilerimarş"}) do
			if k == v then return true end
		end
		if k:find("ileri", 1, true) and #k <= 12 then return true end
