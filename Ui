local function createUICorner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = p
    return c
end

local function createStroke(p, thickness, color)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = thickness
    stroke.Color = color
    stroke.Parent = p
    return stroke
end

local function createGradient(p, color1, color2)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, color1), ColorSequenceKeypoint.new(1, color2)})
    gradient.Parent = p
    return gradient
end

local function createProfileImage(userId, size)
    local img = Instance.new("ImageButton")
    img.Size = size or UDim2.new(0, 48, 0, 48)
    img.BackgroundTransparency = 1
    img.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. userId .. "&width=100&height=100&format=png"
    img.ScaleType = Enum.ScaleType.Fit
    img.ClipsDescendants = true
    img.AutoButtonColor = true
    return img
end

