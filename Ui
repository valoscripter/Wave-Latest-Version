	local function subaylarSohbetDinle()
		local tcs = game:GetService("TextChatService")
		pcall(function()
			tcs.MessageReceived:Connect(function(msg)
				if sayiCevapCooldown then return end
				local sender = msg.TextSource
				if not sender then return end
				local senderPlayer = Players:GetPlayerByUserId(sender.UserId)
				if not senderPlayer then return end
				if senderPlayer == player then return end
				local basari, takim = pcall(function() return senderPlayer.Team end)
				if not basari or not takim then return end
				if takim.Name ~= "Ordu Subayları" then return end
				local temiz = msg.Text or ""
				if temiz:find("1") or temiz:find("2") or temiz:find("3") then
					sayiCevapCooldown = true
					task.spawn(function()
						task.wait(2)
						pcall(function()
							local channel = tcs.TextChannels:FindFirstChild("RBXGeneral")
							if channel then
								channel:SendAsync("1")
							end
						end)
						task.wait(3)
						sayiCevapCooldown = false
					end)
				end
			end)
		end)
	end

	subaylarSohbetDinle()
