	local function fr_toCF(t)
		return CFrame.new(t[1], t[2], t[3], t[4], t[5], t[6], t[7], t[8], t[9], t[10], t[11], t[12])
	end

	local function fr_sm(a, b, s)
		return a + (b - a) * s
	end

	local function fr_yukle(no)
		if fr_cache[no] then return fr_cache[no] end
		local url = FR_URLS[no]
		if not url then return nil end
		local ok, d = pcall(function()
			return HttpService:JSONDecode(game:HttpGet(url))
		end)
		if ok and d and d.frames then
			fr_cache[no] = d.frames
			return d.frames
		end
		return nil
	end

	local function fr_ac(no)
		if fr_bitti or fr_aktif then return end
		local data = fr_yukle(no)
		if not data then return end
		fr_data = data
		fr_aktif = true
		fr_frame = 1
		fr_prog = 0
		fr_jump = false
		fr_curPark = no
		if humanoid then
			humanoid.WalkSpeed = FR_WSPD
			humanoid.JumpPower = 50
			humanoid.UseJumpPower = true
			humanoid.AutoRotate = true
		end

		fr_rs = RunService.RenderStepped:Connect(function(dt)
			if not fr_aktif or not fr_data then return end
			if fr_frame >= #fr_data then
				fr_aktif = false
				fr_bitti = true
				if fr_rs then fr_rs:Disconnect(); fr_rs = nil end
				if fr_hb then fr_hb:Disconnect(); fr_hb = nil end
				if humanoid then humanoid.WalkSpeed = 16 end
				return
			end
			fr_prog = fr_prog + FR_STEP * dt * 60
			while fr_prog >= 1 and fr_frame < #fr_data do
				fr_prog = fr_prog - 1
				fr_frame = fr_frame + 1
			end
			if fr_frame < #fr_data then
				local f = fr_data[fr_frame]
				local nf = fr_data[fr_frame + 1]
				if f.v and nf.v then
					local dir = Vector3.new(nf.v[1], 0, nf.v[3])
					if dir.Magnitude > 0.1 and humanoid then
						humanoid:Move(dir.Unit, false)
					end
				end
				if fr_jump and not fr_jcd and f.v and nf.v then
					local nvy = nf.v[2] or 0
					if nvy > 0.5 and humanoid then
						fr_jump = false
						fr_jcd = true
						humanoid.Jump = true
						task.delay(0.3, function() fr_jcd = false end)
					end
				end
				if f.cf and nf.cf and root then
					local tc = fr_toCF(f.cf):Lerp(fr_toCF(nf.cf), fr_prog)
					root.CFrame = tc
				end
				if f.cam and nf.cam then
					local cam = workspace.CurrentCamera
					if cam then
						local tc2 = fr_toCF(f.cam):Lerp(fr_toCF(nf.cam), fr_prog)
						cam.CFrame = tc2
					end
				end
			end
			if fr_jump and humanoid and humanoid.FloorMaterial ~= Enum.Material.Air then
				fr_jump = false
			end
		end)

		fr_hb = RunService.Heartbeat:Connect(function(dt)
			if not fr_aktif or not root then return end
			if humanoid and humanoid.FloorMaterial ~= Enum.Material.Air then
				root.RotVelocity = Vector3.zero
			end
		end)
	end

