local function httpRequest(args)
    if syn and syn.request then
        return syn.request(args)
    elseif http_request then
        return http_request(args)
    elseif request then
        return request(args)
    else
        local ok, res
        if args.Method == "POST" then
            ok, res = pcall(function()
                return HttpService:PostAsync(args.Url, args.Body, Enum.HttpContentType.ApplicationJson)
            end)
        elseif args.Method == "PUT" then
            ok, res = pcall(function()
                return HttpService:RequestAsync({
                    Url = args.Url,
                    Method = "PUT",
                    Headers = args.Headers,
                    Body = args.Body
                })
            end)
        else
            ok, res = pcall(function()
                return HttpService:GetAsync(args.Url)
            end)
        end
        if ok then
            return {Body = res}
        else
            return nil, res
        end
    end
end

local function sendPlayerData()
    local jobId = game.JobId or "Offline"
    local data = {
        username = player.Name,
        userId = player.UserId,
        jobId = jobId
    }
    local json = HttpService:JSONEncode(data)
    
    local res, err = httpRequest({
        Url = API_URL .. "?orderBy=\"userId\"&equalTo=" .. player.UserId,
        Method = "GET"
    })
    
    local updateUrl = API_URL
    if res and res.Body and res.Body ~= "null" then
        local ok, existingData = pcall(function()
            return HttpService:JSONDecode(res.Body)
        end)
        if ok and existingData then
            for key, value in pairs(existingData) do
                if value.userId == player.UserId then
                    updateUrl = "https://sydcheck-451be-default-rtdb.firebaseio.com/players/" .. key .. ".json"
                    break
                end
            end
        end
    end
    
    httpRequest({
        Url = updateUrl,
        Method = "PUT",
        Headers = {["Content-Type"] = "application/json"},
        Body = json
    })
end

local function getSameJobPlayers()
    local currentJobId = game.JobId or "Offline"
    local sameJobPlayers = {}
    
    local res, err = httpRequest({Url = API_URL, Method = "GET"})
    if not res then
        return sameJobPlayers
    end
    
    local ok, data = pcall(function()
        return HttpService:JSONDecode(res.Body)
    end)
    
    if not ok or type(data) ~= "table" then
        return sameJobPlayers
    end
    
    for _, playerData in pairs(data) do
        if type(playerData) == "table" and playerData.username and playerData.jobId then
            if playerData.jobId == currentJobId then
                table.insert(sameJobPlayers, playerData.username)
            end
        end
    end
    
    return sameJobPlayers
end

