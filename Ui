	local function pozisyonDoluMu(index, umursaSubay, isSTS)
		local pozisyon = pozisyonlar[index]
		if not pozisyon then return false, nil, false end
		local pozisyonPos = pozisyon.cframe.Position
		local trigger = pozisyonTriggers[index]

		local occupiedFromDB = getOccupiedPositions(isSTS)
		if occupiedFromDB[index] then
			return true, occupiedFromDB[index], false
		end

		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local charPos = p.Character.HumanoidRootPart.Position
				if math.abs(charPos.Y - pozisyonPos.Y) < 5 then
					local yatayMesafe = (Vector3.new(charPos.X, 0, charPos.Z) - Vector3.new(pozisyonPos.X, 0, pozisyonPos.Z)).Magnitude
					local pozisyondaMi = false

					if trigger and trigger.Parent then
						local triggerPos = trigger.Position
						local size = trigger.Size / 2
						if math.abs(charPos.X - triggerPos.X) <= size.X + 1 and
						   math.abs(charPos.Y - triggerPos.Y) <= size.Y + 2 and
						   math.abs(charPos.Z - triggerPos.Z) <= size.Z + 1 then
							pozisyondaMi = true
						end
					end
					if yatayMesafe < POZISYON_YARI_CAP then pozisyondaMi = true end

					if pozisyondaMi then
						local subay = oyuncuSubayMi(p)
						if subay then return true, p.Name, true end
						if oyuncuTakimdaMi(p) then return true, p.Name, false end
					end
				end
			end
		end
		return false, nil, false
	end

	local function enUygunPozisyonuBul(isSTS)
		if not root then return TOPLAM_POZISYON end

		local occupied = getOccupiedPositions(isSTS)

		for i = 1, TOPLAM_POZISYON do
			local dolu, _, _ = pozisyonDoluMu(i, true, isSTS)
			if not dolu and not occupied[i] then
				return i
			end
		end
		return nil
	end

	local function yumusakDonus(hedefAci)
		if not root then return end
		local baslangicAci = math.rad(root.Orientation.Y)
		local hedefRadyan = math.rad(hedefAci)
		local fark = math.atan2(math.sin(hedefRadyan - baslangicAci), math.cos(hedefRadyan - baslangicAci))
		if math.abs(fark) < 0.01 then return end
		local adimSayisi = 10
		for i = 1, adimSayisi do
			if not root then break end
			local yeniAci = baslangicAci + (fark * i / adimSayisi)
			root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, yeniAci, 0)
			task.wait(0.008)
		end
		if root then root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, hedefRadyan, 0) end
	end

	local function aciKontrolveKoru()
		if not root or not sabitAciBelirlendi or not sabitBakisAcisi then return end
		if math.abs(root.Orientation.Y - sabitBakisAcisi) > 1 then
			root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(sabitBakisAcisi), 0)
		end
	end

	local function aciKorumayiBaslat()
