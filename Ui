local existingJobIds = {}
local lastDisplayedTimestamps = {}
local lastJobIdUserId

local function updateJobIds()
    local res, err = httpRequest({Url = API_URL, Method = "GET"})
    if not res then return end
    
    local ok, data = pcall(function()
        return HttpService:JSONDecode(res.Body)
    end)
    if not ok or type(data) ~= "table" then return end
    
    local newJobIds = {}
    for _, item in pairs(data) do
        if type(item) == "table" and item.timestamp and item.username and item.userId and item.jobId then
            table.insert(newJobIds, item)
        end
    end
    
    table.sort(newJobIds, function(a, b)
        return a.timestamp < b.timestamp
    end)
    
    local isAtBottom = JobIdBox.CanvasPosition.Y >= JobIdBox.CanvasSize.Y.Offset - JobIdBox.AbsoluteWindowSize.Y - 5
    
    for _, item in ipairs(newJobIds) do
        if not existingJobIds[item.timestamp] then
            local last = lastDisplayedTimestamps[item.userId]
            if not last or os.difftime(item.timestamp, last) >= 1 then
                local label = createJobIdLabel(item)
                label.LayoutOrder = #existingJobIds + 1
                label.Parent = JobIdBox
                existingJobIds[item.timestamp] = true
                lastDisplayedTimestamps[item.userId] = item.timestamp
                lastJobIdUserId = item.userId
            end
        end
    end
    
    task.defer(function()
        JobIdBox.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y)
        if isAtBottom then
            JobIdBox.CanvasPosition = Vector2.new(0, JobIdBox.CanvasSize.Y.Offset)
        end
    end)
end

local function clearAndRefresh()
    for _, child in ipairs(JobIdBox:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    existingJobIds = {}
    lastDisplayedTimestamps = {}
    updateJobIds()
    notify("Job ID'ler yenilendi!")
end

