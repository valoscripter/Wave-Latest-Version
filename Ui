local currentJobId = game.JobId
local displayedPlayers = {}

local function updatePlayerList()
    local success, res = pcall(function()
        return httpRequest({Url = API_URL, Method = "GET"})
    end)
    
    if not success or not res then
        return
    end
    
    local decodeSuccess, data = pcall(function()
        return HttpService:JSONDecode(res.Body)
    end)
    
    if not decodeSuccess or type(data) ~= "table" then
        return
    end
    
    local playersWithSameJobId = {}
    local playerMap = {}
    
    for _, item in pairs(data) do
        if type(item) == "table" and item.jobId and item.username and item.userId then
            if item.jobId == currentJobId then
                local key = tostring(item.userId)
                if not playerMap[key] then
                    playerMap[key] = {
                        username = item.username,
                        userId = item.userId,
                        timestamp = item.timestamp or 0
                    }
                    table.insert(playersWithSameJobId, playerMap[key])
                else
                    if item.timestamp and item.timestamp > playerMap[key].timestamp then
                        playerMap[key].timestamp = item.timestamp
                    end
                end
            end
        end
    end
    
    table.sort(playersWithSameJobId, function(a, b)
        return a.username < b.username
    end)
    
    for _, child in ipairs(PlayerBox:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    displayedPlayers = {}
    
    for _, playerData in ipairs(playersWithSameJobId) do
        local label = createPlayerLabel(playerData.username, playerData.userId)
        label.Parent = PlayerBox
        displayedPlayers[playerData.userId] = true
    end
    
    task.defer(function()
        PlayerBox.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y)
    end)
    
    if #playersWithSameJobId > 0 then
        notify(string.format("Aynı Job ID'ye sahip %d oyuncu bulundu!", #playersWithSameJobId))
    else
        notify("Bu Job ID'ye sahip başka oyuncu bulunamadı.")
    end
end

