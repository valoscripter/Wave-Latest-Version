local function updatePlayerList()
    local res, err = httpRequest({Url = API_URL, Method = "GET"})
    if not res then
        return
    end
    
    local ok, data = pcall(function()
        return HttpService:JSONDecode(res.Body)
    end)
    
    if not ok or type(data) ~= "table" then
        return
    end
    
    currentJobId = game.JobId or "Offline"
    JobIdLabel.Text = "Job ID: " .. currentJobId
    
    local playersList = {}
    local usersSeen = {}
    
    for key, playerData in pairs(data) do
        if type(playerData) == "table" and playerData.username and playerData.userId and playerData.jobId then
            if not usersSeen[playerData.userId] then
                usersSeen[playerData.userId] = true
                table.insert(playersList, playerData)
            end
        end
    end
    
    table.sort(playersList, function(a, b)
        if a.jobId == currentJobId and b.jobId ~= currentJobId then
            return true
        elseif a.jobId ~= currentJobId and b.jobId == currentJobId then
            return false
        else
            return a.username < b.username
        end
    end)
    
    for _, container in ipairs(PlayerListFrame:GetChildren()) do
        if container:IsA("Frame") and container ~= UIList and container ~= UIPadding then
            container:Destroy()
        end
    end
    
    local guideCount = 0
    for _, playerData in ipairs(playersList) do
        if playerData.jobId == currentJobId and playerData.userId ~= player.UserId then
            guideCount = guideCount + 1
        end
    end
    
    if guideCount > 0 then
        local guideTitle = Instance.new("TextLabel")
        guideTitle.Size = UDim2.new(1, 0, 0, 35)
        guideTitle.BackgroundColor3 = Color3.fromRGB(255, 170, 0, 50)
        guideTitle.Text = "✨ " .. guideCount .. " REHBER (GUIDE) BULUNDU ✨"
        guideTitle.TextColor3 = Color3.fromRGB(255, 200, 100)
        guideTitle.Font = Enum.Font.GothamBold
        guideTitle.TextSize = 14
        guideTitle.TextWrapped = true
        guideTitle.Parent = PlayerListFrame
        createUICorner(guideTitle, 6)
    end
    
    for _, playerData in ipairs(playersList) do
        local card = createPlayerCard(playerData, currentJobId)
        card.Parent = PlayerListFrame
    end
    
    task.defer(function()
        PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y)
    end)
end

