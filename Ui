	local don_busy = false
	local don_aktifBag = nil
	local don_baslangic = 0
	local don_hedefAci = 0
	local don_suresi = 0
	local don_basT = 0

	local function don_akilli(sim, hed)
		if sim == hed then return sim end
		if (sim == "sag" and hed == "sol") or (sim == "sol" and hed == "sag") then
			return "merkez"
		end
		return hed
	end

	local function smoothStep(t)
		t = math.clamp(t, 0, 1)
		return t * t * (3 - 2 * t)
	end

	local function don_don(hedefYon)
		if not root or not root.Parent then return end
		if don_busy then return end
		local gercek = don_akilli(don_cur, hedefYon)
		if gercek == don_cur then return end
		if don_aktifBag then don_aktifBag:Disconnect(); don_aktifBag = nil end
		don_busy = true
		don_baslangic = don_yon[don_cur]
		don_hedefAci = don_yon[gercek]
		don_suresi = 0.6 + math.random() * 0.7
		don_basT = tick()
		local hedefG = gercek
		don_aktifBag = RunService.RenderStepped:Connect(function()
			if not root or not root.Parent then
				don_aktifBag:Disconnect()
				don_aktifBag = nil
				don_busy = false
				return
			end
			local elapsed = tick() - don_basT
			local t = math.clamp(elapsed / don_suresi, 0, 1)
			local ease = smoothStep(t)
			local titreme = (1 - ease) ^ 2 * 3.5 * (math.sin(elapsed * 60) * 0.5 + math.sin(elapsed * 37) * 0.3 + math.sin(elapsed * 89) * 0.2)
			root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(don_baslangic + (don_hedefAci - don_baslangic) * ease + titreme), 0)
			if t >= 1 then
				root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(don_hedefAci), 0)
				don_aktifBag:Disconnect()
				don_aktifBag = nil
				don_busy = false
				don_cur = hedefG
			end
		end)
	end

	task.spawn(function()
		while true do
			task.wait(5)
			if don_busy and don_basT > 0 and (tick() - don_basT) > don_suresi + 2 then
				don_busy = false
				if don_aktifBag then don_aktifBag:Disconnect(); don_aktifBag = nil end
				if root and root.Parent then
					root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(don_yon.merkez), 0)
					don_cur = "merkez"
				end
			end
		end
	end)

