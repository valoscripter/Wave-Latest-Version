local PlaceId = game.PlaceId

local _sh_AllIDs = {}
local _sh_foundAnything = ""
local _sh_actualHour = os.date("!*t").hour

local _sh_File = pcall(function()
	_sh_AllIDs = game:GetService("HttpService"):JSONDecode(readfile("NotSameServers.json"))
end)
if not _sh_File then
	table.insert(_sh_AllIDs, _sh_actualHour)
	writefile("NotSameServers.json", game:GetService("HttpService"):JSONEncode(_sh_AllIDs))
end

local function _sh_TPReturner()
	local Site
	if _sh_foundAnything == "" then
		Site = game.HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
	else
		Site = game.HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100&cursor=" .. _sh_foundAnything))
	end
	if Site.nextPageCursor and Site.nextPageCursor ~= "null" and Site.nextPageCursor ~= nil then
		_sh_foundAnything = Site.nextPageCursor
	end
	local num = 0
	for i, v in pairs(Site.data) do
		local Possible = true
		local ID = tostring(v.id)
		if tonumber(v.maxPlayers) > tonumber(v.playing) then
			for _, Existing in pairs(_sh_AllIDs) do
				if num ~= 0 then
					if ID == tostring(Existing) then
						Possible = false
					end
				else
					if tonumber(_sh_actualHour) ~= tonumber(Existing) then
						pcall(function()
							delfile("NotSameServers.json")
							_sh_AllIDs = {}
							table.insert(_sh_AllIDs, _sh_actualHour)
						end)
					end
				end
				num = num + 1
			end
			if Possible == true then
				table.insert(_sh_AllIDs, ID)
				task.wait()
				pcall(function()
					writefile("NotSameServers.json", game:GetService("HttpService"):JSONEncode(_sh_AllIDs))
					task.wait()
					game:GetService("TeleportService"):TeleportToPlaceInstance(PlaceId, ID, game.Players.LocalPlayer)
				end)
				task.wait(4)
			end
		end
	end
end

local function serverhop()
	while task.wait() do
		pcall(function()
			_sh_TPReturner()
			if _sh_foundAnything ~= "" then
				_sh_TPReturner()
			end
		end)
	end
end

