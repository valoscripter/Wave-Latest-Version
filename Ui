    msg.TextColor3 = Color3.new(1, 1, 1)
    msg.Font = Enum.Font.GothamBold
    msg.TextSize = 18
    msg.TextWrapped = true
    msg.Text = content
    msg.Parent = ScreenGui
    createUICorner(msg, 8)
    msg:TweenPosition(UDim2.new(0.5, -150, 0, 10), "Out", "Quad", 0.4, true)
    task.delay(3, function()
