local scriptUsers = {}

local function createUserCard(user)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0, 95, 0, 100)
    card.BackgroundColor3 = Colors.SurfaceLight
    card.BackgroundTransparency = 0.3
    card.Parent = UsersContent

    local cardCorner = Instance.new("UICorner")
    cardCorner.CornerRadius = UDim.new(0, 12)
    cardCorner.Parent = card

    local avatar = Instance.new("ImageLabel")
    avatar.Size = UDim2.new(0, 50, 0, 50)
    avatar.Position = UDim2.new(0.5, -25, 0, 10)
    avatar.BackgroundColor3 = Colors.Card
    avatar.BackgroundTransparency = 0.5
    avatar.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. user.UserId .. "&width=100&height=100&format=png"
    avatar.Parent = card

    local avatarCorner = Instance.new("UICorner")
    avatarCorner.CornerRadius = UDim.new(1, 0)
    avatarCorner.Parent = avatar

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -10, 0, 30)
    nameLabel.Position = UDim2.new(0, 5, 0, 68)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = user.Name
    nameLabel.TextColor3 = Colors.Text
    nameLabel.Font = Enum.Font.LuckiestGuy
    nameLabel.TextSize = 11
    nameLabel.TextWrapped = true
    nameLabel.TextScaled = true
    nameLabel.Parent = card

    -- Check if user is using the script
    if scriptUsers[user.UserId] then
        local gradient = Instance.new("UIGradient")
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 100, 255)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 180, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 100, 255))
        })
        gradient.Rotation = 45
        gradient.Parent = nameLabel
        TweenService:Create(gradient, TweenInfo.new(3, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, -1), { Rotation = 225 }):Play()
    end

    local cardGradient = Instance.new("UIGradient")
    cardGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Colors.Primary),
        ColorSequenceKeypoint.new(0.5, Colors.Text),
        ColorSequenceKeypoint.new(1, Colors.Primary)
    })
    cardGradient.Rotation = 45
    cardGradient.Transparency = NumberSequence.new(0.7)
    cardGradient.Parent = card
    TweenService:Create(cardGradient, TweenInfo.new(3, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, -1), { Rotation = 225 }):Play()
    return card
end

local function updateUserList()
    for _, child in ipairs(UsersContent:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    for _, user in ipairs(Players:GetPlayers()) do
        createUserCard(user)
    end
end

local function refreshScriptUsers()
    scriptUsers = getScriptUsersInServer()
end

