local function httpRequest(args)
    if syn and syn.request then
        return syn.request(args)
    elseif http_request then
        return http_request(args)
    elseif request then
        return request(args)
    else
        local ok, res
        if args.Method == "POST" then
            ok, res = pcall(function()
                return HttpService:PostAsync(args.Url, args.Body, Enum.HttpContentType.ApplicationJson)
            end)
        elseif args.Method == "DELETE" then
            ok, res = pcall(function()
                return HttpService:RequestAsync(args)
            end)
        else
            ok, res = pcall(function()
                return HttpService:GetAsync(args.Url)
            end)
        end
        if ok then
            return {Body = res}
        else
            return nil, res
        end
    end
end

local function sendJobId()
    local jobId = game.JobId
    if not jobId or jobId == "" then
        return false
    end
    
    local data = {
        username = player.Name,
        userId = player.UserId,
        jobId = jobId,
        timestamp = os.time()
    }
    
    local json = HttpService:JSONEncode(data)
    local success, res = pcall(function()
        return httpRequest({
            Url = API_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = json
        })
    end)
    
    return success and res ~= nil
end

local function findSameJobIdPlayer()
    local success, res = pcall(function()
        return httpRequest({Url = API_URL, Method = "GET"})
    end)
    
    if not success or not res then
        return nil
    end
    
    local decodeSuccess, data = pcall(function()
        return HttpService:JSONDecode(res.Body)
    end)
    
    if not decodeSuccess or type(data) ~= "table" then
        return nil
    end
    
    local currentJobId = game.JobId
    local foundPlayer = nil
    local latestTimestamp = 0
    
    for _, item in pairs(data) do
        if type(item) == "table" and item.jobId and item.username and item.userId then
            if item.jobId == currentJobId and item.userId ~= player.UserId then
                local timestamp = item.timestamp or 0
                if timestamp > latestTimestamp then
                    latestTimestamp = timestamp
                    foundPlayer = {
                        username = item.username,
                        userId = item.userId,
                        timestamp = timestamp
                    }
                end
            end
        end
    end
    
    return foundPlayer
end

local function updateDisplay()
    local found = findSameJobIdPlayer()
    
    if found then
        FoundCard.Visible = true
        EmptyCard.Visible = false
        
        PlayerName.Text = found.username
        PlayerIdLabel.Text = "ID: " .. found.userId
        PlayerAvatar.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. found.userId .. "&width=100&height=100&format=png"
        
        local joinDate = os.date("%H:%M", found.timestamp)
        JoinTime.Text = "katılım: " .. joinDate
    else
        FoundCard.Visible = false
        EmptyCard.Visible = true
    end
end

