			humanoid.WalkSpeed = 16
			humanoid.AutoRotate = true
		end
		isMoving = false
		currentPozisyonIndex = nil
		if kontrolBaglanti then kontrolBaglanti:Disconnect(); kontrolBaglanti = nil end
		aciKorumayiDurdur()
		sabitAciBelirlendi = false
	end

	local function pozisyonDegistir(hedefIndex, isSTS)
		if isMoving then return false end
		if not root or not humanoid then return false end
		if hedefIndex == currentPozisyonIndex then return false end

		local hedefKayit = pozisyonlar[hedefIndex]
		if not hedefKayit then return false end

		local dolu, _, _ = pozisyonDoluMu(hedefIndex, true, isSTS)
		if dolu then return false end

		isMoving = true
		local hedefPos = hedefKayit.cframe.Position

		humanoid.AutoRotate = true
		task.wait(0.05)
		humanoid.WalkSpeed = 16
		humanoid:MoveTo(hedefPos)

		local ulasildi = false
		local baglanti = humanoid.MoveToFinished:Connect(function(reached) if reached then ulasildi = true end end)
		local baslangic = os.clock()

		while not ulasildi and (os.clock() - baslangic) < 15 do
			if not root or not humanoid then break end
			local suAnDolu, isgalci = pozisyonDoluMu(hedefIndex, true, isSTS)
			if suAnDolu and isgalci ~= player.Name then
				humanoid:MoveTo(root.Position)
				task.wait(0.05)
				break
			end
			if (root.Position - hedefPos).Magnitude < HEDEF_ULASIM_MESAFESI then
				humanoid.WalkSpeed = 8
				ulasildi = true
				break
			end
			task.wait(0.05)
		end
		baglanti:Disconnect()

		if ulasildi and root and humanoid then
			local sonDolu, sonOyuncu = pozisyonDoluMu(hedefIndex, true, isSTS)
			if sonDolu and sonOyuncu ~= player.Name then
				isMoving = false
				task.wait(0.2)
				local yeniHedef = enUygunPozisyonuBul(isSTS)
				if yeniHedef then pozisyonDegistir(yeniHedef, isSTS) end
				return false
			end
			humanoid:MoveTo(hedefPos)
			task.wait(0.1)

			yumusakDonus(hedefKayit.aci)
			sabitBakisAcisi = hedefKayit.aci
			sabitAciBelirlendi = true
			humanoid.AutoRotate = false
			aciKorumayiBaslat()

			currentPozisyonIndex = hedefIndex
			sendPosition(hedefIndex, isSTS)
		end
		isMoving = false
		return ulasildi
	end

	local function otomatikKontrol(isSTS)
		if not root or not humanoid or isMoving or not otomatikKontrolAktif then return end

		if currentPozisyonIndex == nil then
			local enBos = enUygunPozisyonuBul(isSTS)
			if enBos then pozisyonDegistir(enBos, isSTS) end
			return
		end

		local suAnDolu, isgalci = pozisyonDoluMu(currentPozisyonIndex, true, isSTS)
		if suAnDolu and isgalci ~= player.Name then
			local yeniHedef = enUygunPozisyonuBul(isSTS)
			if yeniHedef and yeniHedef ~= currentPozisyonIndex then
				pozisyonDegistir(yeniHedef, isSTS)
			end
			return
		end

		local dahaIyiPozisyon = enUygunPozisyonuBul(isSTS)
		if dahaIyiPozisyon and dahaIyiPozisyon < currentPozisyonIndex then
			pozisyonDegistir(dahaIyiPozisyon, isSTS)
		end
	end

	local function sflAc()
		if otomatikKontrolAktif then return end
		otomatikKontrolAktif = true
		currentPozisyonIndex = nil
		if kontrolBaglanti then kontrolBaglanti:Disconnect() end
		sonKontrol = 0

		sabitAciBelirlendi = false
		if humanoid then
			humanoid.AutoRotate = true
		end

		kontrolBaglanti = RunService.Heartbeat:Connect(function()
			if not otomatikKontrolAktif then return end
			local simdi = tick()
			if simdi - sonKontrol >= KONTROL_ARALIGI then
				sonKontrol = simdi
				otomatikKontrol(false)
			end
		end)
	end

	local TAKIP_MESAFESI = 5
	local YAKIN_MESAFE = 1.5

	local takipAktif = false
	local komutan = nil
	local takipBag = nil
	local toolConnection = nil
	local oncekiTool = nil

	local function TakipInstanceleriAl(hrp)
		local bv = hrp:FindFirstChild("TakipBV")
		if not bv then
			bv = Instance.new("BodyVelocity")
			bv.Name = "TakipBV"
			bv.MaxForce = Vector3.new(1e6, 0, 1e6)
			bv.Velocity = Vector3.zero
			bv.Parent = hrp
		end
		local bg = hrp:FindFirstChild("TakipBG")
		if not bg then
			bg = Instance.new("BodyGyro")
			bg.Name = "TakipBG"
			bg.MaxTorque = Vector3.new(0, 1e6, 0)
			bg.P = 3000
			bg.D = 300
			bg.CFrame = hrp.CFrame
			bg.Parent = hrp
		end
		return bv, bg
