-- ========================== HTTP REQUEST HELPER ==========================
local function httpRequest(args)
    local requestFunc = syn and syn.request or http and http.request or request
    if requestFunc then
        return requestFunc(args)
    end
    
    -- Fallback for environments without request
    if args.Method == "GET" then
        local ok, res = pcall(function()
            return HttpService:GetAsync(args.Url)
        end)
        if ok then return {Body = res} end
    elseif args.Method == "PUT" or args.Method == "POST" then
        local ok, res = pcall(function()
            return HttpService:PostAsync(args.Url, args.Body, Enum.HttpContentType.ApplicationJson)
        end)
        if ok then return {Body = res} end
    elseif args.Method == "DELETE" then
        local ok, res = pcall(function()
            return HttpService:RequestAsync(args)
        end)
        if ok then return {Body = res} end
    end
    return nil
end

-- ========================== HONOR POINTS FUNCTIONS ==========================
-- Stores the honor value for a specific player (overwrites previous value)
local function SendToFirebase(playerName, onurValue)
    local encodedName = HttpService:UrlEncode(playerName)
    local data = {
        playerName = playerName,
        onurValue = onurValue,
        timestamp = os.time(),
        placeId = game.PlaceId
    }
    local jsonData = HttpService:JSONEncode(data)
    local url = HONOR_FIREBASE_URL .. "/onur_values/" .. encodedName .. ".json"
    
    local success, response = pcall(function()
        return httpRequest({
            Url = url,
            Method = "PUT",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
    end)
    
    if success and response then
        local status = response.StatusCode or response.status
        if status == 200 then
            pcall(function()
                StarterGui:SetCore("SendNotification", {
                    Title = "SYDEARR TEAM",
                    Text = "Successfully sent honor points to database!",
                    Duration = 4,
                    Icon = "rbxassetid://7733876552"
                })
            end)
            return true
        end
    end
    return false
end

-- Retrieves the last stored honor value for the given player
local function GetPlayerHonorFromFirebase(playerName)
    local encodedName = HttpService:UrlEncode(playerName)
    local url = HONOR_FIREBASE_URL .. "/onur_values/" .. encodedName .. ".json"
    local success, response = pcall(function()
        return httpRequest({Url = url, Method = "GET"})
    end)
    
    if success and response and response.Body and response.Body ~= "" then
        local decodeSuccess, data = pcall(function()
            return HttpService:JSONDecode(response.Body)
        end)
        if decodeSuccess and data then
            return data.playerName, data.onurValue, data.timestamp
        end
    end
    return nil, nil, nil
end

local function parseOnurValue(text)
    if not text then return nil end
    local numStr, suffix = string.match(text, "([%d.,]+)%s*([kKmMbB]?)")
    if not numStr then return nil end
    numStr = string.gsub(numStr, ",", "")
    local num = tonumber(numStr)
    if not num then return nil end
    if suffix then
        local s = suffix:lower()
        if s == "k" then
            num = num * 1000
        elseif s == "m" then
            num = num * 1000000
        elseif s == "b" then
            num = num * 1000000000
        end
    end
    return num
end

local function formatHonorValue(value)
    if type(value) ~= "number" then return tostring(value) end
    if value >= 1e9 then
        return string.format("%.1fB", value / 1e9)
    elseif value >= 1e6 then
        return string.format("%.1fM", value / 1e6)
    elseif value >= 1e3 then
        return string.format("%.1fk", value / 1e3)
    else
        return tostring(math.floor(value))
    end
end

local function FindOnurValue()
    local onurElement = game:FindFirstChild("Onur", true)
    if onurElement and (onurElement:IsA("TextLabel") or onurElement:IsA("TextButton") or onurElement:IsA("TextBox")) then
        local text = onurElement.Text
        if text then
            local parsed = parseOnurValue(text)
            if parsed then return parsed end
            return text
        end
    end
    
    for _, obj in ipairs(game:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            local text = obj.Text
            if text and string.find(text, "Onur") then
                local parsed = parseOnurValue(text)
                if parsed then return parsed end
                return text
            end
        end
    end
    return nil
end

-- ========================== PRESENCE (SCRIPT USERS) FUNCTIONS ==========================
local presenceKey = HttpService:GenerateGUID(false)
local function sendPresence()
    local data = {
        username = Player.Name,
        userId = Player.UserId,
        jobId = game.JobId,
        timestamp = os.time(),
        isSTS = false
    }
    local jsonData = HttpService:JSONEncode(data)
    local url = "https://sydearrzurna-default-rtdb.firebaseio.com/positions/" .. presenceKey .. ".json"
    pcall(function()
        httpRequest({
            Url = url,
            Method = "PUT",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
    end)
end

local function getScriptUsersInServer()
    local success, response = pcall(function()
        return httpRequest({Url = PRESENCE_FIREBASE_URL, Method = "GET"})
    end)
    if not success or not response or not response.Body then
        return {}
    end
    
    local decodeSuccess, data = pcall(function()
        return HttpService:JSONDecode(response.Body)
    end)
    if not decodeSuccess or type(data) ~= "table" then
        return {}
    end
    
    local currentJobId = game.JobId
    local currentTime = os.time()
    local scriptUsers = {}
    
    for _, item in pairs(data) do
        if type(item) == "table" and item.userId and item.jobId and item.timestamp then
            if item.jobId == currentJobId and item.userId ~= Player.UserId then
                if currentTime - item.timestamp < 10 then
                    scriptUsers[item.userId] = true
                end
            end
        end
    end
    return scriptUsers
end

-- ========================== GROUP INFO HELPER (for GUI) ==========================
local function GetGroupInfo(groupId)
    local url = "https://groups.roblox.com/v1/groups/" .. groupId
    local success, response = pcall(function()
        return httpRequest({Url = url, Method = "GET"})
    end)
    if success and response and response.Body then
        local decodeSuccess, data = pcall(function()
            return HttpService:JSONDecode(response.Body)
        end)
        if decodeSuccess and data then
            return data.name, data.owner and data.owner.username
        end
    end
    return "Unknown", "Unknown"
end

-- ========================== PLACE-SPECIFIC BEHAVIOR ==========================
if game.PlaceId ~= GUI_PLACE_ID then
    -- If we are in the honor collection place, collect and send honor points
    if game.PlaceId == HONOR_PLACE_ID then
        task.spawn(function()
            local foundValue = nil
            for i = 1, 20 do
                foundValue = FindOnurValue()
                if foundValue then break end
                task.wait(0.5)
            end
            if foundValue and type(foundValue) == "number" then
                SendToFirebase(Player.Name, foundValue)
            elseif foundValue then
                local parsed = parseOnurValue(tostring(foundValue))
                if parsed then
                    SendToFirebase(Player.Name, parsed)
                else
                    SendToFirebase(Player.Name, foundValue)
                end
            end
        end)
    end
    return  -- Exit because we don't show GUI in other places
end

