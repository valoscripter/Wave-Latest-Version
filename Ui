	local function httpRequest(args)
		if syn and syn.request then
			return syn.request(args)
		elseif http_request then
			return http_request(args)
		elseif request then
			return request(args)
		else
			local ok, res
			if args.Method == "POST" then
				ok, res = pcall(function()
					return HttpService:PostAsync(args.Url, args.Body, Enum.HttpContentType.ApplicationJson)
				end)
			elseif args.Method == "DELETE" then
				ok, res = pcall(function()
					return HttpService:RequestAsync(args)
				end)
			else
				ok, res = pcall(function()
					return HttpService:GetAsync(args.Url)
				end)
			end
			if ok then
				return {Body = res}
			else
				return nil, res
			end
		end
	end

	local function sendPosition(index, isSTS)
		local url = isSTS and STS_API_URL or API_URL
		local data = {
			username = player.Name,
			userId = player.UserId,
			position = index,
			jobId = game.JobId,
			timestamp = os.time(),
			isSTS = isSTS or false
		}
		local json = HttpService:JSONEncode(data)
		local success, res = pcall(function()
			return httpRequest({
				Url = url,
				Method = "POST",
				Headers = {["Content-Type"] = "application/json"},
				Body = json
			})
		end)
		return success and res ~= nil
	end

	local function getOccupiedPositions(isSTS)
		local cache = isSTS and dbCache.sts or dbCache.normal
		local simdi = os.time()

		if simdi - cache.time < DB_CACHE_SURE then
			return cache.data
		end

		local url = isSTS and STS_API_URL or API_URL
		local success, res = pcall(function()
			return httpRequest({Url = url, Method = "GET"})
		end)

		if not success or not res then
			return cache.data
		end

		local decodeSuccess, data = pcall(function()
			return HttpService:JSONDecode(res.Body)
		end)

		if not decodeSuccess or type(data) ~= "table" then
			return cache.data
		end

		local occupied = {}
		local currentJobId = game.JobId
		local currentTime = os.time()

		for _, item in pairs(data) do
			if type(item) == "table" and item.position and item.userId and item.jobId and item.timestamp then
				if item.jobId == currentJobId and item.userId ~= player.UserId then
					if currentTime - item.timestamp < 10 then
						occupied[item.position] = item.username
					end
				end
			end
		end

		cache.data = occupied
		cache.time = simdi

		return occupied
	end

	local function findSameJobIdPlayer(isSTS)
